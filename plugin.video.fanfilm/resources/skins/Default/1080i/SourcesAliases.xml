<?xml version="1.0" encoding="UTF-8"?>
<window xmlns:ff="ff">

  <ff:defines>

    <macro name="button">
      <!-- button  -->
      <param name="onright" value="{onleft}"/>
      <param name="onup" value=""/>
      <param name="ondown" value=""/>
      <control type="button" id="{id}">
        <!-- <width>250</width> -->
        <width/>
        <left/>
        <right/>
        <top>{80 * (n-1) if n &gt; 0 else ''}</top>
        <bottom>{80 * (-n-1) if n &lt; 0 else ''}</bottom>
        <height>60</height>
        <align>center</align>
        <texturenofocus border="6">dialogs/button-nofocus.png</texturenofocus>
        <texturefocus border="6">dialogs/button-focus.png</texturefocus>
        <colordiffuse/>
        <textcolor>B3FFFFFF</textcolor>
        <focusedcolor>ffffffff</focusedcolor>
        <font ff:style="normal">font13</font>
        <!-- :translate=false: -->
        <label text="Defaults">{label}</label>
        <!-- <textwidth>230</textwidth> -->
        <onright>{onright}</onright>
        <onleft>{onleft}</onleft>
        <onup>{onup}</onup>
        <ondown>{ondown}</ondown>
      </control>
    </macro>

  </ff:defines>

  <!-- <zorder>7</zorder> -->
  <coordinates>
    <top>0</top>
    <left>0</left>
    <width>1920</width>
    <height>1080</height>
  </coordinates>
  <!-- <defaultcontrol>51</defaultcontrol> -->

  <controls>
    <!-- dimmed background -->
    <control type="image">
      <top/>
      <left/>
      <width>1920</width>
      <height>1080</height>
      <texture border="10" colordiffuse="BF000000">white.png</texture>
    </control>

    <!-- window -->
    <control type="group">
      <centertop>50%</centertop>
      <centerleft>50%</centerleft>
      <top/>
      <left/>
      <width>1280</width>
      <height>920</height>
      <font>font_title</font>
      <control type="image">
        <colordiffuse>D9202E39</colordiffuse>
        <texture border="20">dialogs/rounded.png</texture>
      </control>
      <control type="image">
        <colordiffuse>D9141519</colordiffuse>
        <texture border="20">dialogs/rounded.png</texture>
        <bordersize>4</bordersize>
      </control>

      <!-- title container -->
      <control type="group">
        <top>10</top>
        <centerleft>50%</centerleft>
        <left>10</left>
        <right>10</right>
        <bottom/>
        <height>70</height>

        <!-- source list -->
        <control type="label" id="21">
          <top>0</top>
          <bottom>0</bottom>
          <left>0</left>
          <right>0</right>
          <align>center</align>
          <aligny>center</aligny>
          <font ff:style="heading">font40_title</font>
          <!-- L(30528, 'Alternative titles') -->
          <label>$ADDON[plugin.video.fanfilm 30528]</label>  <!-- Alternative titles -->
        </control>

      </control>  <!-- title container -->

      <!-- Separator -->
      <control type="image">
        <colordiffuse>D9202E39</colordiffuse>
        <texture border="2">white.png</texture>
        <height>2</height>
        <width>1230</width>
        <top>90</top>
        <centerleft>50%</centerleft>
        <left/>
      </control>

      <!-- content container -->
      <control type="group">
        <left>5</left>
        <right>5</right>
        <top>80</top>
        <bottom>15</bottom>

        <control id="51" type="fixedlist">
          <top>20</top>
          <bottom>20</bottom>
          <description>Aliases</description>
          <orientation>vertical</orientation>
          <pagecontrol>200</pagecontrol>
          <visible>true</visible>
          <movement>10</movement>
          <focusposition>0</focusposition>
          <onright>200</onright>
          <onleft>32</onleft>
          <height/>
          <left>20</left>
          <right>320</right>
          <width/>
          <!-- <itemlayout height="116" width="1460"> -->

          <itemlayout height="70">
            <control type="group">
              <!-- <animation effect="fade" start="100" end="70" time="0" condition="true">Conditional</animation> -->
              <control type="image">
                <width>60</width>
                <height>40</height>
                <centertop>50%</centertop>
                <top/>
                <left>15</left>
                <colordiffuse>ffcccccc</colordiffuse>
                <texture border="0">$INFO[ListItem.Property(flag)]</texture>
                <bordersize>0</bordersize>
              </control>
              <control type="label">
                <top/>
                <bottom/>
                <left>90</left>
                <right/>
                <align>left</align>
                <aligny>center</aligny>
                <font ff:style="small">font13</font>
                <!-- :translate=false: -->
                <label>$INFO[ListItem.Property(country), [UPPERCASE][B],[/B][/UPPERCASE]]</label>
              </control>
              <control type="label">
                <top/>
                <bottom/>
                <left>150</left>
                <right/>
                <align>left</align>
                <aligny>center</aligny>
                <font ff:style="normal">font13</font>
                <!-- :translate=false: -->
                <label>$INFO[ListItem.Label]</label>
              </control>
            </control>
          </itemlayout>

          <focusedlayout height="70">
            <control type="group">
              <!-- <animation effect="zoom" start="100" end="102" time="100" center="650,50" tween="sine" easing="inout">Focus</animation> -->
              <control type="image">
                <colordiffuse>ffcccccc</colordiffuse>
                <texture border="7">dialogs/frame.r7.w1.t3.png</texture>
                <bordersize>0</bordersize>
              </control>
              <control type="image">
                <width>60</width>
                <height>40</height>
                <centertop>50%</centertop>
                <top/>
                <left>15</left>
                <colordiffuse>ffcccccc</colordiffuse>
                <texture border="0">$INFO[ListItem.Property(flag)]</texture>
                <bordersize>0</bordersize>
              </control>
              <control type="label">
                <top/>
                <bottom/>
                <left>90</left>
                <right/>
                <align>left</align>
                <aligny>center</aligny>
                <font ff:style="small">font13</font>
                <!-- :translate=false: -->
                <label>$INFO[ListItem.Property(country), [UPPERCASE][B],[/B][/UPPERCASE]]</label>
                <textcolor>FFFFEE99</textcolor>
              </control>
              <control type="label">
                <top/>
                <bottom/>
                <left>150</left>
                <right/>
                <align>left</align>
                <aligny>center</aligny>
                <font ff:style="normal">font13</font>
                <!-- :translate=false: -->
                <label>$INFO[ListItem.Label]</label>
                <!-- <label>$INFO[Window.Property(item.colored.default)]</label> -->
                <textcolor>FFFFEE99</textcolor>
              </control>
            </control>
          </focusedlayout>
        </control>

        <!-- Separator -->
        <control type="image">
          <top>30</top>
          <left/>
          <right>308</right>
          <width>3</width>
          <height>775</height>
          <colordiffuse>D9202E39</colordiffuse>
          <texture border="2">white.png</texture>
          <visible>!Control.IsVisible(200)</visible>
        </control>

        <control type="scrollbar" id="200">
            <top>30</top>
            <left/>
            <right>308</right>
            <width>3</width>
            <height>775</height>
            <texturesliderbackground colordiffuse="D9202E39">white.png</texturesliderbackground>
            <texturesliderbar colordiffuse="FF555556">white.png</texturesliderbar>
            <texturesliderbarfocus colordiffuse="ffcccccc">white.png</texturesliderbarfocus>
            <showonepage>false</showonepage>
            <orientation>vertical</orientation>
            <onleft>51</onleft>
            <onright>32</onright>
        </control>

        <!-- buttons container -->
        <control type="group">
          <top>20</top>
          <bottom>20</bottom>
          <left/>
          <right>20</right>
          <width>280</width>

          <!-- OK -->
          <!-- <ff:macro macro="button" id="30" label="$LOCALIZE[186]" n="-2" onup="32" ondown="32" onleft="" /> -->
          <!-- Cancel -->
          <ff:macro macro="button" id="32" label="$LOCALIZE[222]" n="-1" onleft="200" onright="51"/>

        </control>  <!-- buttons container -->

      </control>  <!-- content container -->

    </control>  <!-- window -->
  </controls>

</window><!--
 vim:sw=2:ts=2:sts=2:
-->