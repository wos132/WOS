<?xml version="1.0" encoding="UTF-8"?>
<window xmlns:ff="ff">
  <ff:defines>

    <macro name="alternatives_button">
      <param name="top" value=""/>
      <param name="right" value="20"/>
      <param name="onup" value="{120 + n - 1}"/>
      <param name="ondown" value="{120 + n + 1}"/>
      <param name="onleft" value="{100 + n}"/>
      <param name="onright" value="{100 + n}"/>
      <control type="group">
        <height>64</height>
        <width>64</width>
        <right>{right}</right>
        <left/>
        <top>{top or (10 + (n-1) * 80)}</top>
        <bottom/>
        <control type="button" id="{120 + n}">
          <height/>
          <width/>
          <right>0</right>
          <left>0</left>
          <top>0</top>
          <bottom>0</bottom>
          <aligny>center</aligny>
          <align>center</align>
          <texturenofocus border="6">dialogs/button-nofocus.png</texturenofocus>
          <texturefocus border="6">dialogs/button-focus.png</texturefocus>
          <colordiffuse/>
          <onleft>{onleft}</onleft>
          <onright>{onright}</onright>
          <onup>{onup}</onup>
          <ondown>{ondown}</ondown>
        </control>
        <control type="image">
          <height>52</height>
          <width>52</width>
          <top>6</top>
          <left>6</left>
          <right/>
          <bottom/>
          <aligny>center</aligny>
          <align>center</align>
          <texture colordiffuse="B3FFFFFF">icons/list.32.png</texture>
        </control>
      </control>
    </macro>

    <macro name="badge.modified">
      <param name="top" value=""/>
      <param name="left" value="-15"/>
      <param name="bottom" value=""/>
      <param name="right" value=""/>
      <control type="image">
        <visible>String.IsEqual(Window.Property(search.modified.{key}),true)</visible>
        <height>32</height>
        <width>32</width>
        <top>{top}</top>
        <left>{left}</left>
        <right>{right}</right>
        <bottom>{bottom}</bottom>
        <aligny>center</aligny>
        <align>center</align>
        <texture colordiffuse="B3FFFF99">icons/modified.32.png</texture>
      </control>
    </macro>

  </ff:defines>

